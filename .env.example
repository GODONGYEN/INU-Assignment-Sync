# --------------------------------------------
# 기본 사이트 정보
# --------------------------------------------
LOGIN_URL=https://cyber.inu.ac.kr/login.php
ASSIGNMENTS_URL=https://cyber.inu.ac.kr/calendar/view.php?view=month
BASE_URL=https://cyber.inu.ac.kr

# --------------------------------------------
# 로그인 방식
# true  : 브라우저를 띄운 뒤 사용자가 직접 로그인
# false : 아래 계정/selector로 자동 로그인 시도
# --------------------------------------------
USE_MANUAL_LOGIN=true
GUI_MODE=false
E_LEARNING_ID=
E_LEARNING_PASSWORD=

# --------------------------------------------
# 브라우저 실행 옵션
# --------------------------------------------
HEADLESS=false
SLOW_MO_MS=0
PAGE_TIMEOUT_MS=15000
LOGIN_WAIT_TIMEOUT_MS=180000

# --------------------------------------------
# 캘린더 설정
# --------------------------------------------
CALENDAR_NAME=INU 과제
EVENT_DURATION_MINUTES=30
TIMEZONE=Asia/Seoul
DATABASE_PATH=data/sync_state.sqlite3
CALENDAR_MONTHS_BACK=2
CALENDAR_MONTHS_FORWARD=6
INCLUDE_PAST_ASSIGNMENTS=false
REMINDER_MINUTES=1440,180
DRY_RUN=true

# --------------------------------------------
# 로그인 관련 selector 예시
# 실제 사이트 구조에 맞게 개발자 도구로 확인 후 수정
# --------------------------------------------
LOGIN_ID_SELECTOR=input[name='username']
LOGIN_PASSWORD_SELECTOR=input[name='password']
LOGIN_SUBMIT_SELECTOR=input[name='loginbutton']
LOGIN_SUCCESS_WAIT_SELECTOR=body:not(#page-login-index)

# --------------------------------------------
# 캘린더 / 과제 selector 예시
# 실제 사이트 구조에 맞게 개발자 도구로 확인 후 수정
# --------------------------------------------
CALENDAR_TABLE_SELECTOR=table.calendarmonth.calendartable
CURRENT_MONTH_SELECTOR=h2.current
CALENDAR_EVENT_SELECTOR=ul.events-new li.calendar_event_course
CALENDAR_EVENT_LINK_SELECTOR=a
CALENDAR_DAY_CELL_SELECTOR=td.day, td.duration_course
CALENDAR_DAY_NUMBER_SELECTOR=div.day

ASSIGNMENT_ROW_SELECTOR=.assignment-row
ASSIGNMENT_COURSE_SELECTOR=.course-name
ASSIGNMENT_TITLE_SELECTOR=.assignment-title
ASSIGNMENT_DUE_DATE_SELECTOR=.due-date
ASSIGNMENT_DUE_TIME_SELECTOR=.due-time
ASSIGNMENT_DUE_TEXT_SELECTOR=.due-datetime
ASSIGNMENT_LINK_SELECTOR=a.assignment-link

# --------------------------------------------
# 캘린더 이벤트 제목 필터
# 너무 강한 필터를 피하기 위해 쉼표로 자유롭게 수정 가능
# --------------------------------------------
INCLUDE_KEYWORDS=과제,assignment,Assign,Submission,제출,연습문제,lab,quiz
